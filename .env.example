# PowerDev Environment Variables

# MongoDB Connection
# Option 1: Full MongoDB URI (for Render deployment)
MONGO_URI=mongodb+srv://lifeflow_user:vinisha00@@lifeflow.sflewbn.mongodb.net/?appName=LifeFlow

# Option 2: Individual components (for local development)
# Uncomment these if not using MONGO_URI above
# MONGO_USER=admin
# MONGO_PASSWORD=your_password
# MONGO_HOST=your_cluster.mongodb.net
# MONGO_CLUSTER=mongodb+srv
# MONGO_DB=powerdev

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000

# CORS (for development)
CORS_ORIGINS=*

# Secret Key (add for production)
# SECRET_KEY=your-secret-key-here
